# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# HTTP Basic Auth password (required on a shared/hosted instance)
# Leave blank to disable auth (local dev only)
DASHBOARD_PASS=change_me

# Username shown in the browser login prompt (default: chi)
DASHBOARD_USER=chi

# Port the server listens on (default: 3000)
PORT=3000
